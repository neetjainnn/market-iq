{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python Static Server",
      "runtimeExecutable": "/usr/bin/python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "npx serve",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-l", "3000"],
      "port": 3000
    },
    {
      "name": "npx http-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "8080"],
      "port": 8080
    }
  ]
}
